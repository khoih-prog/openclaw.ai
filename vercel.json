{
  "routes": [
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "trust.openclaw.ai" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/blog#security" }
    },
    {
      "src": "^/trust(/.*)?$",
      "status": 308,
      "headers": { "Location": "/blog#security" }
    },
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "clawd.bot" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/$1" }
    },
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "www.clawd.bot" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/$1" }
    }
  ]
}
